---
import DarkmodeSwitch from "../components/darkmode-switch.astro";
import Navigation from "../components/navigation.astro";
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>lean-stack.rocks</title>
    <script is:inline>
      document.documentElement.classList.toggle(
        "dark",
        localStorage.theme === "dark" ||
          (!localStorage.theme &&
            matchMedia("(prefers-color-scheme: dark)").matches)
      );
    </script>
  </head>
  <body
    class="bg-slate-50 dark:bg-slate-900 text-emerald-900 dark:text-emerald-50"
  >
    <header class="flex items-center h-16 px-4 py-2">
      <div class="grow flex justify-center">
        <Navigation />
      </div>
      <div>
        <DarkmodeSwitch />
      </div>
    </header>
    <main class="mt-8 my-12 mx-0 px-4">
      <slot />
    </main>
  </body>
</html>

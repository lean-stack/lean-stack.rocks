---
import DarkmodeSwitch from "../components/darkmode-switch.astro";
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>lean-stack.rocks</title>
    <script is:inline>
      document.documentElement.classList.toggle(
        "dark",
        localStorage.theme === "dark" ||
          (!localStorage.theme &&
            matchMedia("(prefers-color-scheme: dark)").matches)
      );
    </script>
  </head>
  <body
    class="bg-slate-50 dark:bg-slate-900 text-emerald-900 dark:text-emerald-50"
  >
    <header class="flex items-center h-12 px-4 py-2">
      <div class="ml-auto">
        <DarkmodeSwitch />
      </div>
    </header>
    <slot />
  </body>
</html>
